# Pinned npm version — keep in sync with the root Dockerfile.cli and
# Dockerfile.web.
ARG NPM_VERSION=11.14.1

# node:22-bookworm-slim
FROM node:22-bookworm-slim@sha256:c29352e5563688e726158e23480bc2d4bd0af23bbdd055f8b837a12ecfd6a2a1
ARG NPM_VERSION
WORKDIR /app
RUN npx --yes npm@${NPM_VERSION} install -g npm@${NPM_VERSION} \
    && apt-get -o Acquire::Check-Valid-Until=false -o Acquire::Check-Date=false update \
    && apt-get install -y python3 make g++ \
    && rm -rf /var/lib/apt/lists/*
COPY . .
RUN npm ci --ignore-scripts \
    && npm rebuild tree-sitter-swift 2>&1 \
    && node -e "require('tree-sitter-swift')" \
    && (npm rebuild 2>&1 || true) \
    && cd node_modules/tree-sitter-kotlin && npx --yes node-gyp rebuild 2>&1
CMD ["npx", "vitest", "run", "test/integration", "--reporter=verbose"]
